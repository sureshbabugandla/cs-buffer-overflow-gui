@startuml sequence
!include style.iuml
title Buffer Overflow Demo — Request Lifecycle (all use cases)

actor User
participant "Browser\n(index.html\nvanilla JS + fetch)" as B
participant "Flask app\n(app.py · Werkzeug)" as F
participant "subprocess\n(OS process manager)" as OS
participant "C binary\n(vuln / hardened)" as C
participant "Logger +\nLogBuffer (deque)" as L

== Page load & live log polling ==
User -> B : open http://localhost:5001
B -> F : GET /
F --> B : HTML + CSS + JS
loop every 1.5 s (and after every action)
  B -> F : GET /api/backend-logs
  F --> B : { lines:[ ... ] }
  B -> B : render live log panel
end

== Scenario buttons (A Crash / B Corrupt / C Privilege) ==
User -> B : click a scenario button
B -> B : read input box value
B -> F : POST /api/<route>  { input }
activate F
F -> F : get_json(); choose binary + mode
F -> L : log INVOKE
F -> OS : subprocess.run([binary, mode, input], timeout=5s)
activate OS
OS -> C : exec child process
activate C
C -> C : strcpy() (unsafe) or snprintf() (safe)

alt long input, UNSAFE build -> return address smashed
  C ->x OS : illegal memory access
  OS --> F : killed, returncode = -11 (SIGSEGV)
  F -> F : classify => "crashed"
else 17-24 bytes, flag-unsafe -> neighbour overwritten
  C --> OS : stdout evidence, exit 3
  OS --> F : returncode 3 + stdout
  F -> F : classify => "corrupted"
else 17-24 bytes, auth-unsafe -> is_admin flipped
  C --> OS : access=GRANTED, exit 4
  OS --> F : returncode 4 + stdout
  F -> F : classify => "escalated"
else HARDENED build -> canary / FORTIFY fires
  C ->x OS : abort + "*** buffer overflow detected ***"
  OS --> F : returncode -6 (SIGABRT) + stderr
  F -> F : classify => "prevented"
else SAFE mode, oversized -> bounds check refuses
  C --> OS : stderr "rejected", exit 2
  OS --> F : returncode 2 + stderr
  F -> F : classify => "rejected"
else normal input
  C --> OS : stdout "processed", exit 0
  OS --> F : returncode 0
  F -> F : classify => "ok"
end
deactivate C
deactivate OS
F -> L : log RESULT (+ STDERR)
F --> B : JSON { outcome, detail, memory, access, exit, signal }
deactivate F
B -> B : build result panel + memory proof
B -> F : GET /api/backend-logs (immediate refresh)
F --> B : { lines:[ ... ] }

== Verify protections button ==
User -> B : click "Verify protections"
B -> F : GET /api/verify
activate F
F -> OS : objdump / readelf on BOTH binaries
OS --> F : canary refs, NX, size, sha256
F --> B : JSON { vulnerable, hardened }
deactivate F
B -> B : render backend-evidence panel
@enduml
